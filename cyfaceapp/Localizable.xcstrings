    "de.cyface.app.error.authenticatornotinitialized" : {
      "comment" : "The authenticator was not initialized and thus authentication is not possible. This should not happen, if the app was properly implemented.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Unerwarteter Fehler: Der Authentifizierer wurde nicht initialisiert. Dadurch ist es der App nicht möglich sie zu anzumelden. Bitte wenden Sie sich an support@cyface.de und melden Sie das Problem!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unexpected error: Authenticator not initialized. Authentication failed. Please report this issue to support@cyface.de!"
          }
        }
      }
    },
    "de.cyface.app.error.invalidurl" : {
      "comment" : "An invalid URL was provided to the application.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Unerwarteter Fehler: Ungültige URL. Bitte wenden Sie sich an support@cyface.de und beschreiben Sie Ihr Problem!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Unexpected error: Invalid URL. Please contact support@cyface.de and describe your issue!\""
          }
        }
      }
    },
    "de.cyface.app.error.nosuchmeasurement" : {
      "comment" : "The app tried to load a measurement that did not exist!",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Unerwarteter Fehler: Die App hat versucht eine Messung zu laden die es nicht gibt. Ihre Datenbank scheint korrumpiert zu sein. Bitte wenden Sie sich an support@cyface.de und beschreiben Sie Ihr Problem!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Unexpected error: Measurement not found. Your database appears to be corrupted. Please contact support@cyface.de and describe your issue!\""
          }
        }
      }
    },
    "de.cyface.app.error.notinitialized" : {
      "comment" : "The view was not properly initialized, which is most likely caused if the persistence layer was not setup properly.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Unerwarteter Fehler: Die Anwendung wurde nicht richtig hoch gefahren. Dies kann passieren, wenn ihre Datenbank abgestürzt ist. Bitte wenden Sie sich an support@cyface.de und beschreiben Sie Ihr Problem!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Unexpected error: App failed to start correctly. This may be due to a database crash. Please contact support@cyface.de and describe your issue!\""
          }
        }
      }
    },
    "de.cyface.app.error.unabletosubscribetoupdates" : {
      "comment" : "The application was unable to subscribe to update on the running measurement!",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Unerwarteter Fehler: Die Anwendung kann keine Aktualisierungen von der laufenden Messung erhalten. Bitte wenden Sie sich an support@cyface.de uns beschreiben Sie Ihr Problem!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Unexpected error: Unable to receive updates from the current measurement. Please contact support@cyface.de and describe your issue!\""
          }
        }
      }
    },
